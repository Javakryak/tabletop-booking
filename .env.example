# Root environment example. Do not put real secrets here.

# Shared app URLs
APP_ENV=local
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:3001/api/v1
API_DOCS_ENABLED=true
CORS_ORIGIN=http://localhost:3000

# Local infrastructure
DATABASE_URL=postgresql://board_club:board_club_local_password@localhost:5432/board_club_booking
TEST_DATABASE_URL=postgresql://board_club:board_club_local_password@localhost:5432/board_club_booking_test
REDIS_URL=redis://localhost:6379

# Auth and Telegram placeholders. Replace in local .env only.
JWT_SECRET=change-me-in-local-env
JWT_EXPIRES_IN=7d
TELEGRAM_AUTH_MAX_AGE_SECONDS=86400
LEGAL_REQUIRED_DOCUMENT_TYPES=privacy_policy,personal_data_consent
TELEGRAM_BOT_TOKEN=replace-with-local-development-token
TELEGRAM_WEBHOOK_SECRET=replace-with-local-webhook-secret
TELEGRAM_WEBHOOK_URL=

# Reminder lead time for bot booking reminders.
BOT_REMINDER_LEAD_MINUTES=180
