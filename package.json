{
  "name": "tabletop-booking",
  "version": "0.1.0",
  "private": true,
  "description": "AI-assisted fullstack booking system for a board game and wargame club.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.0.8",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.1",
    "@prisma/client": "6.19.3",
    "eslint": "9.39.1",
    "prettier": "3.7.4",
    "prisma": "6.19.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.49.0"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "scripts": {
    "dev": "pnpm --recursive --if-present --parallel run dev",
    "build": "pnpm --recursive --if-present run build",
    "lint": "eslint .",
    "typecheck": "pnpm --recursive --if-present run typecheck",
    "test": "pnpm --recursive --if-present run test",
    "test:e2e": "pnpm --recursive --if-present run test:e2e",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "db:seed": "prisma db seed --schema prisma/schema.prisma",
    "db:studio": "prisma studio --schema prisma/schema.prisma",
    "format": "prettier \"*.{js,json,yml,yaml}\" \"apps/**/*.{js,jsx,ts,tsx,json,css,md,yml,yaml}\" \"packages/**/*.{js,jsx,ts,tsx,json,css,md,yml,yaml}\" --check",
    "postinstall": "prisma generate --schema prisma/schema.prisma"
  }
}
