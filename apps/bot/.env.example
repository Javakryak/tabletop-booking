# Bot environment example. Do not put real secrets here.

APP_ENV=local
API_BASE_URL=http://localhost:3001/api/v1
APP_BASE_URL=http://localhost:3000

TELEGRAM_BOT_TOKEN=replace-with-local-development-token
TELEGRAM_WEBHOOK_SECRET=replace-with-local-webhook-secret
TELEGRAM_WEBHOOK_URL=

# Comma-separated Telegram user IDs allowed to run /admin, /pending, /today.
# Example: BOT_ADMIN_TELEGRAM_IDS=123456789,987654321
BOT_ADMIN_TELEGRAM_IDS=

# JWT access token for a user with admin or owner role.
# Used by bot commands to read /admin/bookings from API.
BOT_ADMIN_API_TOKEN=

# Timezone used for /today booking summary grouping.
BOT_SCHEDULE_TIMEZONE=Europe/Moscow

# Notification delivery worker settings.
BOT_NOTIFICATION_BATCH_SIZE=20
BOT_NOTIFICATION_POLL_INTERVAL_MS=30000

# local: polling; staging/production: webhook.
# In webhook mode, TELEGRAM_WEBHOOK_URL and TELEGRAM_WEBHOOK_SECRET are required.
TELEGRAM_UPDATE_MODE=polling
