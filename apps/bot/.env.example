# Bot environment example. Do not put real secrets here.

APP_ENV=local
API_BASE_URL=http://localhost:3001/api/v1
APP_BASE_URL=http://localhost:3000

TELEGRAM_BOT_TOKEN=replace-with-local-development-token
TELEGRAM_WEBHOOK_SECRET=replace-with-local-webhook-secret
TELEGRAM_WEBHOOK_URL=

# local: polling; staging/production: webhook.
TELEGRAM_UPDATE_MODE=polling
