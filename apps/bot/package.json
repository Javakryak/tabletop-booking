{
  "name": "@tabletop-booking/bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "grammy": "^1.38.4"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "node --env-file=.env --import tsx src/main.ts",
    "start": "node dist/main.js",
    "test": "node --import tsx --test \"test/**/*.test.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "tsx": "^4.20.6"
  }
}
